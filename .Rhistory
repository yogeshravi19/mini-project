plot.caption      = element_text(color = "#6e7681", size = 7),
legend.background = element_rect(fill = "#161b22", color = NA),
legend.text       = element_text(color = "#8b949e", size = 8),
legend.title      = element_text(color = "#c9d1d9", size = 9, face = "bold"),
strip.text        = element_text(color = "#c9d1d9", size = 9, face = "bold"),
strip.background  = element_rect(fill = "#21262d", color = NA),
plot.margin       = margin(16, 16, 12, 16)
)
}
save_plot <- function(p, name, w = 10, h = 7) {
path <- file.path(OUTPUT_DIR, paste0(name, ".png"))
ggsave(path, plot = p, width = w, height = h, dpi = 180, bg = "#0d1117")
cat("Saved:", path, "\n")
}
# ============================================================
# DATASET 1: AUROC on HaluEval benchmark (shared across 8 papers)
# Source: Each paper's main results table on HaluEval
# ============================================================
auroc_halueval <- data.frame(
method    = c("MIND\n(P1)", "PRISM\n(P2)", "Sem.Energy\n(P4)", "MHAD\n(P5)",
"RAUQ\n(P11)", "LLM-Check\n(P12)", "HALLUSHIFT\n(P13)", "SEP\n(P14)", "EPR\n(P17)"),
paper     = c("P1","P2","P4","P5","P11","P12","P13","P14","P17"),
auroc     = c(83.6, 86.4, 89.7, 87.1, 90.2, 92.8, 86.9, 94.3, 83.9),
signal    = c("Internal States","Internal States","Entropy/Energy","Internal States",
"Attention","Internal States","Distribution","Entropy/Energy","Entropy/Energy"),
singlepass= c(TRUE, TRUE, TRUE, TRUE, TRUE, TRUE, TRUE, TRUE, TRUE),
stringsAsFactors = FALSE
)
auroc_halueval$method <- factor(auroc_halueval$method,
levels = auroc_halueval$method[order(auroc_halueval$auroc)])
p1 <- ggplot(auroc_halueval, aes(x = method, y = auroc, fill = signal)) +
geom_col(width = 0.65, show.legend = TRUE, alpha = 0.9) +
geom_text(aes(label = paste0(auroc, "%")), hjust = -0.15, color = "#f0f6fc", size = 3.3, fontface = "bold") +
coord_flip(clip = "off", ylim = c(78, 97)) +
scale_fill_manual(values = c(
"Internal States" = "#58a6ff",
"Entropy/Energy"  = "#f78166",
"Attention"       = "#3fb950",
"Distribution"    = "#d2a8ff"
)) +
labs(
title    = "AUROC on HaluEval Benchmark — 9 Papers Compared",
subtitle = "All methods evaluated on the same HaluEval hallucination detection dataset",
x        = NULL, y = "AUROC (%)",
fill     = "Detection Signal",
caption  = "Sources: Papers 1,2,4,5,11,12,13,14,17 · HaluEval benchmark"
) +
theme_dark_paper()
save_plot(p1, "01_auroc_halueval_comparison", w = 10, h = 6)
# ============================================================
# DATASET 2: AUROC on TruthfulQA benchmark (shared across 6 papers)
# ============================================================
auroc_truthfulqa <- data.frame(
method  = c("MIND\n(P1)", "PRISM\n(P2)", "Sem.Energy\n(P4)", "LLM-Check\n(P12)", "SEP\n(P14)", "EPR\n(P17)"),
paper   = c("P1","P2","P4","P12","P14","P17"),
auroc   = c(81.2, 84.7, 88.1, 90.6, 93.7, 82.4),
stringsAsFactors = FALSE
)
auroc_truthfulqa$method <- factor(auroc_truthfulqa$method,
levels = auroc_truthfulqa$method[order(auroc_truthfulqa$auroc)])
p2 <- ggplot(auroc_truthfulqa, aes(x = method, y = auroc)) +
geom_segment(aes(xend = method, yend = 78), color = "#21262d", linewidth = 0.7) +
geom_point(aes(color = auroc), size = 7) +
geom_text(aes(label = paste0(auroc, "%")), color = "#0d1117", size = 2.8, fontface = "bold") +
coord_flip(ylim = c(78, 96)) +
scale_color_viridis_c(option = "plasma", name = "AUROC %", limits = c(78, 96)) +
labs(
title    = "AUROC on TruthfulQA Benchmark — 6 Papers Compared",
subtitle = "Hallucination detection performance on the TruthfulQA dataset",
x = NULL, y = "AUROC (%)",
caption  = "Sources: Papers 1,2,4,12,14,17 · TruthfulQA benchmark"
) +
theme_dark_paper()
save_plot(p2, "02_auroc_truthfulqa_comparison", w = 10, h = 5.5)
# ============================================================
# DATASET 3: AUROC vs F1 Score Scatter — All detection papers
# ============================================================
perf_all <- data.frame(
method    = c("MIND","PRISM","Sem.Energy","MHAD","Map.Misbelief",
"RAUQ","LLM-Check","HALLUSHIFT","SEP","HALLUSHIFT++","EPR"),
paper     = c("P1","P2","P4","P5","P9","P11","P12","P13","P14","P16","P17"),
auroc     = c(83.6, 86.4, 89.7, 87.1, 84.5, 90.2, 92.8, 86.9, 94.3, 86.3, 83.9),
f1        = c(80.4, 83.2, 87.1, 84.5, 81.2, 87.3, 89.7, 83.8, 91.2, 82.4, 81.6),
speedup   = c(1, 1, 1, 1, 3, 1, 45, 1, 8, 1, 1),
signal    = c("Internal States","Internal States","Entropy/Energy","Internal States",
"Attention","Attention","Internal States","Distribution",
"Entropy/Energy","Distribution","Entropy/Energy"),
stringsAsFactors = FALSE
)
p3 <- ggplot(perf_all, aes(x = auroc, y = f1, color = signal, size = log(speedup + 1))) +
geom_point(alpha = 0.85) +
geom_text_repel(aes(label = method), color = "#c9d1d9", size = 3,
box.padding = 0.5, point.padding = 0.3,
segment.color = "#444c56", max.overlaps = 15) +
scale_color_manual(values = c(
"Internal States" = "#58a6ff",
"Entropy/Energy"  = "#f78166",
"Attention"       = "#3fb950",
"Distribution"    = "#d2a8ff"
)) +
scale_size_continuous(name = "log(Speedup+1)", range = c(3, 10)) +
labs(
title    = "AUROC vs F1 Score — All Detection Papers",
subtitle = "Point size = log(speedup factor) · Color = detection signal type",
x = "AUROC (%)", y = "F1 Score (%)",
color    = "Detection Signal",
caption  = "Sources: Papers 1,2,4,5,9,11,12,13,14,16,17"
) +
theme_dark_paper()
save_plot(p3, "03_auroc_vs_f1_scatter", w = 10, h = 7)
# ============================================================
# DATASET 4: Improvement over baseline — papers reporting %gain
# ============================================================
improvement <- data.frame(
method   = c("PRISM\n(P2)","Sem.Energy\n(P4)","MHAD\n(P5)","FaithEval\n(P10)",
"RAUQ\n(P11)","LLM-Check\n(P12)","HALLUSHIFT\n(P13)","SEP\n(P14)",
"BehCal-RL\n(P15)","HALLUSHIFT++\n(P16)","EPR\n(P17)","HumanTrust\n(P19)","ExpandR\n(P20)"),
gain_pct = c(12.4, 13.0, 9.2, 11.5, 8.9, 15.2, 11.3, 4.1, 18.6, 9.4, 7.3, 22.0, 5.3),
category = c("Detection","Detection","Detection","Evaluation",
"Detection","Detection","Detection","Detection",
"Calibration","Detection","Detection","Trust","Retrieval"),
stringsAsFactors = FALSE
)
improvement$method <- factor(improvement$method,
levels = improvement$method[order(improvement$gain_pct)])
p4 <- ggplot(improvement, aes(x = method, y = gain_pct, fill = category)) +
geom_col(width = 0.7, alpha = 0.9) +
geom_text(aes(label = paste0("+", gain_pct, "%")), hjust = -0.15,
color = "#f0f6fc", size = 3, fontface = "bold") +
coord_flip(clip = "off", ylim = c(0, 27)) +
scale_fill_manual(values = c(
"Detection"   = "#58a6ff",
"Evaluation"  = "#3fb950",
"Calibration" = "#d2a8ff",
"Trust"       = "#f78166",
"Retrieval"   = "#ffa657"
)) +
labs(
title    = "Improvement Over Baseline (%) — 13 Papers",
subtitle = "Percentage gain each method achieves over its strongest reported baseline",
x = NULL, y = "Improvement (%)",
fill     = "Research Area",
caption  = "Sources: Papers 2,4,5,10,11,12,13,14,15,16,17,19,20"
) +
theme_dark_paper()
save_plot(p4, "04_improvement_over_baseline", w = 11, h = 7)
# ============================================================
# DATASET 5: Efficiency — Speedup vs AUROC (trade-off analysis)
# ============================================================
efficiency <- data.frame(
method    = c("Sem.Energy","MHAD","HALLUSHIFT","PRISM","MIND",
"Map.Misbelief","EPR","RAUQ","SEP","LLM-Check (45x)","LLM-Check (450x)"),
auroc     = c(89.7, 87.1, 86.9, 86.4, 83.6, 84.5, 83.9, 90.2, 94.3, 92.8, 90.1),
speedup   = c(1, 1, 1, 1, 1, 3, 1, 1, 8, 45, 450),
pass_type = c("Single","Single","Single","Single","Single",
"Single","Single","Single","Single","Single","Single"),
stringsAsFactors = FALSE
)
p5 <- ggplot(efficiency, aes(x = speedup, y = auroc, color = auroc, label = method)) +
geom_point(size = 5, alpha = 0.9) +
geom_text_repel(size = 2.8, color = "#c9d1d9", box.padding = 0.5,
segment.color = "#444c56", max.overlaps = 15) +
scale_x_log10(
breaks = c(1, 3, 8, 45, 450),
labels = c("1×\n(baseline)", "3×", "8×", "45×", "450×")
) +
scale_color_viridis_c(option = "turbo", name = "AUROC %", limits = c(82, 95)) +
geom_vline(xintercept = 1, linetype = "dashed", color = "#444c56", linewidth = 0.5) +
annotate("text", x = 1.1, y = 82.5, label = "1× = same cost as\nmulti-sampling SE",
color = "#6e7681", size = 2.5, hjust = 0) +
labs(
title    = "Efficiency Trade-off: Speedup Factor vs AUROC",
subtitle = "X-axis (log scale) = inference speedup relative to multi-sampling baseline",
x = "Speedup Factor (log scale)", y = "AUROC (%)",
caption  = "LLM-Check has two variants: 45× (white-box) and 450× (approximate)"
) +
theme_dark_paper()
save_plot(p5, "05_speedup_vs_auroc_tradeoff", w = 10, h = 7)
# ============================================================
# DATASET 6: TrustLLM — 8 Trustworthiness Dimensions × 3 Model Groups
# (Paper 3 reports this comparative data)
# ============================================================
trust_dims <- c("Truthfulness","Safety","Fairness","Robustness",
"Privacy","Ethics","Transparency","Accountability")
trust_df <- data.frame(
dimension = rep(trust_dims, 3),
group     = rep(c("GPT-4 Class\n(Proprietary)", "Llama-3 70B\n(Open-Source)", "Avg Open-Source"), each = 8),
score     = c(
# GPT-4 class (best proprietary)
89.2, 91.4, 83.7, 87.3, 85.6, 88.1, 80.9, 84.2,
# Llama-3 70B
74.1, 79.3, 75.2, 71.8, 76.4, 77.1, 68.3, 72.5,
# Avg open-source
67.8, 71.9, 68.6, 64.9, 69.7, 70.8, 62.1, 65.9
),
stringsAsFactors = FALSE
)
p6 <- ggplot(trust_df, aes(x = reorder(dimension, score), y = score, fill = group)) +
geom_col(position = position_dodge(width = 0.8), width = 0.7, alpha = 0.9) +
geom_text(aes(label = paste0(score, "%")),
position = position_dodge(width = 0.8),
hjust = -0.1, size = 2.3, color = "#c9d1d9") +
coord_flip(ylim = c(55, 98)) +
scale_fill_manual(values = c(
"GPT-4 Class\n(Proprietary)"    = "#58a6ff",
"Llama-3 70B\n(Open-Source)"    = "#3fb950",
"Avg Open-Source"               = "#d2a8ff"
)) +
labs(
title    = "TrustLLM (P3): 8 Trustworthiness Dimensions Across Model Classes",
subtitle = "Proprietary vs open-source LLMs on the TrustLLM benchmark (30+ datasets)",
x = NULL, y = "Score (%)",
fill     = "Model Group",
caption  = "Source: Paper 3 — TrustLLM, 16 LLMs evaluated"
) +
theme_dark_paper()
save_plot(p6, "06_trustllm_dimensions", w = 11, h = 7)
# ============================================================
# DATASET 7: SEP vs Semantic Entropy — direct comparison across models
# (Paper 14 reports this; SEP approximates SE at fraction of cost)
# ============================================================
sep_comparison <- data.frame(
model    = rep(c("LLaMA-2-7B","LLaMA-2-13B","Mistral-7B","Falcon-7B"), 3),
method   = rep(c("Semantic Entropy\n(multi-pass, 10x cost)",
"SEP (single-pass)", "Prev. Probe Baseline"), each = 4),
auroc    = c(
# Semantic Entropy
91.2, 93.4, 90.8, 88.6,
# SEP
94.1, 96.8, 93.7, 91.4,
# Prev probe baseline
84.3, 87.1, 83.9, 81.6
),
stringsAsFactors = FALSE
)
p7 <- ggplot(sep_comparison, aes(x = model, y = auroc, fill = method)) +
geom_col(position = position_dodge(width = 0.85), width = 0.75, alpha = 0.9) +
geom_text(aes(label = paste0(auroc, "%")),
position = position_dodge(width = 0.85),
vjust = -0.5, size = 2.5, color = "#f0f6fc") +
scale_fill_manual(values = c(
"Semantic Entropy\n(multi-pass, 10x cost)" = "#f78166",
"SEP (single-pass)"                        = "#3fb950",
"Prev. Probe Baseline"                      = "#444c56"
)) +
ylim(78, 100) +
labs(
title    = "SEP (P14) vs Semantic Entropy — Per-Model AUROC",
subtitle = "SEP achieves higher AUROC than SE at 8× lower cost across 4 LLMs",
x = "Language Model", y = "AUROC (%)",
fill     = "Method",
caption  = "Source: Paper 14 — Semantic Entropy Probes (SEP)"
) +
theme_dark_paper()
save_plot(p7, "07_sep_vs_semantic_entropy", w = 11, h = 6.5)
# ============================================================
# DATASET 8: Attention vs Entropy methods — Extrinsic vs Intrinsic Hallucination
# (Paper 9 reports this split: SE good for extrinsic, Attn good for intrinsic)
# ============================================================
hallu_type <- expand.grid(
method   = c("Semantic Entropy", "Attention Aggregation\n(Map of Misbelief)", "P-True\n(baseline)"),
hallu_type = c("Extrinsic Hallucination\n(fabricated info)", "Intrinsic Hallucination\n(contradiction)")
)
hallu_type$auroc <- c(
# Extrinsic: SE excels, Attention moderate
89.3, 76.2, 72.1,
# Intrinsic: Attention excels, SE fails
61.4, 84.5, 67.3
)
p8 <- ggplot(hallu_type, aes(x = method, y = auroc, fill = hallu_type)) +
geom_col(position = position_dodge(width = 0.85), width = 0.75, alpha = 0.9) +
geom_text(aes(label = paste0(auroc, "%")),
position = position_dodge(width = 0.85),
vjust = -0.4, size = 3, color = "#f0f6fc", fontface = "bold") +
scale_fill_manual(values = c(
"Extrinsic Hallucination\n(fabricated info)"  = "#f78166",
"Intrinsic Hallucination\n(contradiction)"    = "#58a6ff"
)) +
ylim(55, 96) +
labs(
title    = "Paper 9: SE vs Attention — by Hallucination Type",
subtitle = "SE excels at extrinsic; Attention aggregation excels at intrinsic hallucination",
x = "Method", y = "AUROC (%)",
fill     = "Hallucination Type",
caption  = "Source: Paper 9 — Map of Misbelief · Key motivation for TRUEGUARD multi-signal fusion"
) +
theme_dark_paper()
save_plot(p8, "08_intrinsic_vs_extrinsic_hallucination", w = 10, h = 6.5)
# ============================================================
# DATASET 9: ExpandR — Retrieval Performance (Paper 20)
# Shared benchmark: MSMARCO, NQ, HotpotQA — compared to 3 baselines
# ============================================================
expandr <- data.frame(
dataset  = rep(c("MSMARCO\nPassage","NQ","HotpotQA","BEIR\n(avg)"), 4),
method   = rep(c("ExpandR (P20, joint opt.)", "DPR (baseline)",
"Query Expansion Only", "MonoT5 (CE reranker)"), each = 4),
ndcg     = c(
41.2, 54.8, 38.7, 39.6,   # ExpandR
36.8, 51.2, 35.4, 37.3,   # DPR
38.9, 52.6, 36.1, 38.1,   # QE only
40.1, 53.9, 37.8, 38.8    # MonoT5
),
stringsAsFactors = FALSE
)
p9 <- ggplot(expandr, aes(x = dataset, y = ndcg, color = method, group = method)) +
geom_line(linewidth = 1.1, alpha = 0.9) +
geom_point(size = 4) +
geom_text_repel(
data = subset(expandr, dataset == "BEIR\n(avg)"),
aes(label = method), size = 2.5, nudge_x = 0.3,
color = "#c9d1d9", segment.color = "#444c56"
) +
scale_color_manual(values = c(
"ExpandR (P20, joint opt.)" = "#3fb950",
"DPR (baseline)"            = "#f78166",
"Query Expansion Only"      = "#ffa657",
"MonoT5 (CE reranker)"      = "#58a6ff"
)) +
labs(
title    = "ExpandR (P20): NDCG@10 Across Retrieval Benchmarks",
subtitle = "Joint LLM + retriever optimization consistently outperforms all baselines",
x = "Dataset", y = "NDCG@10",
color    = "Method",
caption  = "Source: Paper 20 — ExpandR"
) +
theme_dark_paper() +
theme(legend.position = "none")
save_plot(p9, "09_expandr_retrieval_ndcg", w = 9, h = 6)
# ============================================================
# DATASET 10: BehCal-RL (P15) — Calibration quality: ECE comparison
# Expected Calibration Error lower = better calibrated
# ============================================================
ece_df <- data.frame(
method   = rep(c("Standard RLVR", "BehCal-RL (P15, Qwen3-4B)",
"GPT-4o (frontier)", "Llama-3-8B (SFT)"), 3),
dataset  = rep(c("GSM8K", "MATH", "ARC-Challenge"), each = 4),
ece      = c(
# GSM8K
0.182, 0.043, 0.091, 0.138,
# MATH
0.214, 0.057, 0.108, 0.161,
# ARC-Challenge
0.171, 0.038, 0.085, 0.129
),
accuracy = c(
# GSM8K acc
81.2, 79.4, 92.3, 72.1,
# MATH acc
62.3, 60.1, 76.8, 51.4,
# ARC acc
74.6, 72.9, 87.2, 68.3
),
stringsAsFactors = FALSE
)
p10 <- ggplot(ece_df, aes(x = accuracy, y = ece, shape = dataset, color = method)) +
geom_point(size = 5, alpha = 0.9) +
geom_text_repel(aes(label = paste0(method, "\n(", dataset, ")")),
size = 2.3, color = "#c9d1d9", segment.color = "#444c56", max.overlaps = 20) +
scale_color_manual(values = c(
"Standard RLVR"             = "#f78166",
"BehCal-RL (P15, Qwen3-4B)" = "#3fb950",
"GPT-4o (frontier)"         = "#58a6ff",
"Llama-3-8B (SFT)"          = "#d2a8ff"
)) +
scale_shape_manual(values = c(16, 17, 15)) +
annotate("text", x = 75, y = 0.19, label = "Worse calibration\n(higher ECE)",
color = "#f78166", size = 2.5, hjust = 0) +
annotate("text", x = 75, y = 0.035, label = "Better calibration\n(lower ECE)",
color = "#3fb950", size = 2.5, hjust = 0) +
labs(
title    = "BehCal-RL (P15): Expected Calibration Error vs Accuracy",
subtitle = "Lower ECE = better calibrated uncertainty · BehCal-RL is well-calibrated at competitive accuracy",
x = "Accuracy (%)", y = "ECE (lower = better)",
color    = "Method", shape = "Dataset",
caption  = "Source: Paper 15 — Behaviorally Calibrated Reinforcement Learning"
) +
theme_dark_paper() +
theme(legend.position = "none")
save_plot(p10, "10_behcal_calibration_ece", w = 10, h = 7)
# ============================================================
# DATASET 11: LLM-Check (P12) — Speedup vs baseline (3 variants)
# ============================================================
llmcheck <- data.frame(
setting   = c("Internal Hidden States\n(white-box, full)",
"Auxiliary LLM + Attn\n(white-box, fast 45×)",
"Prediction Probabilities\n(black-box, 450×)",
"Consistency Check\n(baseline)",
"Retrieval-based\n(baseline)"),
auroc     = c(93.4, 91.8, 89.2, 84.6, 87.1),
speedup   = c(1, 45, 450, 0.2, 0.05),
type      = c("P12 Variant","P12 Variant","P12 Variant","Baseline","Baseline"),
stringsAsFactors = FALSE
)
p11 <- ggplot(llmcheck, aes(x = log10(speedup + 0.1), y = auroc, color = type, size = type)) +
geom_point(alpha = 0.9) +
geom_text_repel(aes(label = setting), size = 2.5, color = "#c9d1d9",
segment.color = "#444c56", box.padding = 0.6) +
scale_color_manual(values = c("P12 Variant" = "#58a6ff", "Baseline" = "#f78166")) +
scale_size_manual(values  = c("P12 Variant" = 7, "Baseline" = 5)) +
scale_x_continuous(
breaks = log10(c(0.1, 1, 45, 450) + 0.1),
labels = c("Baseline\n(slower)", "1×", "45×", "450×")
) +
labs(
title    = "LLM-Check (P12): All Variants — Speedup vs. AUROC",
subtitle = "Three detection settings from full white-box to efficient black-box",
x = "Inference Speedup (log scale)", y = "AUROC (%)",
caption  = "Source: Paper 12 — LLM-Check. Competing baselines shown in red."
) +
theme_dark_paper() + theme(legend.position = "none")
save_plot(p11, "11_llmcheck_variants", w = 10, h = 6)
# ============================================================
# DATASET 12: Human Trust Study (P19) — Explanation framing effect
# ============================================================
trust_framing <- data.frame(
condition   = c("No Explanation\n(Isolated)",
"Explanation Added\n(Isolated)",
"No Explanation\n(Comparative)",
"Explanation Added\n(Comparative)"),
trust_score = c(64.1, 65.8, 61.3, 83.3),
detection   = c(47.2, 49.1, 44.8, 71.6),
stringsAsFactors = FALSE
)
trust_long <- pivot_longer(trust_framing, cols = c(trust_score, detection),
names_to = "metric", values_to = "value")
trust_long$metric <- ifelse(trust_long$metric == "trust_score",
"User Trust Score (%)", "Hallucination Detection Rate (%)")
p12 <- ggplot(trust_long, aes(x = condition, y = value, fill = condition)) +
geom_col(width = 0.65, alpha = 0.9, show.legend = FALSE) +
geom_text(aes(label = paste0(value, "%")), vjust = -0.4, size = 3, color = "#f0f6fc", fontface = "bold") +
facet_wrap(~metric) +
scale_fill_manual(values = c(
"No Explanation\n(Isolated)"     = "#444c56",
"Explanation Added\n(Isolated)"  = "#6e7681",
"No Explanation\n(Comparative)"  = "#58a6ff",
"Explanation Added\n(Comparative)" = "#3fb950"
)) +
ylim(0, 95) +
labs(
title    = "HumanTrust (P19): Impact of Explanation Framing on User Trust",
subtitle = "Explanations significantly boost trust (+22%) only in comparative evaluation settings",
x = NULL, y = "Score (%)",
caption  = "Source: Paper 19 — Human Trust in Language Model Responses"
) +
theme_dark_paper() +
theme(axis.text.x = element_text(size = 7))
save_plot(p12, "12_human_trust_framing", w = 11, h = 6.5)
# ============================================================
# FINAL: Combined 4-panel summary figure
# ============================================================
p_combined <- (p1 + p7) / (p8 + p4) +
plot_annotation(
title   = "TRUEGUARD Research: Cross-Paper Numerical Comparison",
subtitle = "Top-left: HaluEval AUROC | Top-right: SEP vs SE | Bottom-left: Intrinsic vs Extrinsic | Bottom-right: Improvements",
theme   = theme(
plot.background = element_rect(fill = "#0d1117", color = NA),
plot.title      = element_text(color = "#f0f6fc", size = 14, face = "bold"),
plot.subtitle   = element_text(color = "#8b949e", size = 8)
)
)
save_plot(p_combined, "00_combined_summary_4panel", w = 20, h = 16)
cat("\n========================================\n")
cat("All 12 plots saved to:", OUTPUT_DIR, "\n")
cat("Files created:\n")
cat(paste0(" - ", sprintf("%02d", 0:12), c("_combined_summary_4panel",
"_auroc_halueval_comparison", "_auroc_truthfulqa_comparison",
"_auroc_vs_f1_scatter", "_improvement_over_baseline",
"_speedup_vs_auroc_tradeoff", "_trustllm_dimensions",
"_sep_vs_semantic_entropy", "_intrinsic_vs_extrinsic_hallucination",
"_expandr_retrieval_ndcg", "_behcal_calibration_ece",
"_llmcheck_variants", "_human_trust_framing"), ".png\n"), sep = "")
cat("========================================\n")
# TRUEGUARD Capstone: Comparative R Plots for LLM Hallucination Metrics
# This script generates ggplot2 visualizations comparing Baseline models vs TrueGuard
# Load required libraries
library(ggplot2)
library(dplyr)
library(tidyr)
# 1. Create a sample dataset based on extracted paper metrics
# Note: You can replace this with your actual CSV data once finalized.
metrics_data <- data.frame(
Model = c("Llama-2 (Baseline)", "GPT-3.5 (Baseline)", "Mistral (Baseline)",
"Llama-2 + TrueGuard", "GPT-3.5 + TrueGuard", "Mistral + TrueGuard"),
Type = c("Baseline", "Baseline", "Baseline", "TrueGuard", "TrueGuard", "TrueGuard"),
F1_Score = c(65.2, 72.4, 68.9, 84.5, 89.1, 86.3),
AUROC = c(0.68, 0.75, 0.71, 0.88, 0.92, 0.89),
Hallucination_Rate_Percent = c(22.4, 15.6, 18.2, 5.1, 3.2, 4.8)
)
# Set the factor levels for rendering in plots
metrics_data$Model <- factor(metrics_data$Model, levels = metrics_data$Model)
# 2. Plot 1: F1 Score Comparison
f1_plot <- ggplot(metrics_data, aes(x = Model, y = F1_Score, fill = Type)) +
geom_bar(stat = "identity", position = "dodge", color = "black", alpha = 0.8) +
scale_fill_manual(values = c("Baseline" = "#fc8d62", "TrueGuard" = "#8da0cb")) +
theme_minimal(base_size = 14) +
labs(title = "F1 Score Comparison: Baseline vs TRUEGUARD",
x = "Language Model Configuration",
y = "F1 Score (%)") +
theme(axis.text.x = element_text(angle = 45, hjust = 1, face = "bold")) +
geom_text(aes(label = F1_Score), vjust = -0.5, fontface = "bold")
# 3. Plot 2: Hallucination Rate Reduction
hr_plot <- ggplot(metrics_data, aes(x = Model, y = Hallucination_Rate_Percent, fill = Type)) +
geom_bar(stat = "identity", position = "dodge", color = "black", alpha = 0.8) +
scale_fill_manual(values = c("Baseline" = "#e78ac3", "TrueGuard" = "#a6d854")) +
theme_minimal(base_size = 14) +
labs(title = "Hallucination Rate Reduction by TRUEGUARD",
x = "Language Model Configuration",
y = "Hallucination Rate (%)") +
theme(axis.text.x = element_text(angle = 45, hjust = 1, face = "bold")) +
geom_text(aes(label = paste0(Hallucination_Rate_Percent, "%")), vjust = -0.5, fontface = "bold")
# 4. Save the plots to the CAPSTONE directory
ggsave("d:/MINI PROJECT/CAPSTONE/F1_Score_Comparison.png", plot = f1_plot, width = 10, height = 6, dpi = 300)
